# Configuración de Base de Datos
DB_HOST=db
DB_PORT=3306
DB_NAME=camagru
DB_USER=camagru_user
DB_PASS=camagru_password
DB_ROOT_PASS=root_password

# URL de la Aplicación
APP_URL=http://localhost:8080

# Configuración de Correo (usa un servicio como Mailtrap para pruebas)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=your_mailtrap_user
MAIL_PASS=your_mailtrap_password
MAIL_FROM=noreply@camagru.com

# Seguridad
SESSION_SECRET=change_this_to_a_random_string_for_security
